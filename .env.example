# Semantos CellToken Poker — Environment Configuration
#
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Or use .env.live generated by pre-fund.ts for live BSV mode.

# ── BSV Funding ──
# Generate with: bun run show-address
PRIVATE_KEY_WIF=
CHANGE_ADDRESS=

# ── Anchor Mode ──
# stub = no BSV txs (dry run)
# live = broadcast CellTokens to BSV mainnet
ANCHOR_MODE=stub

# Pre-funded tx hex (generated by pre-fund.ts)
FUNDING_TX_HEX=

# ── Fee Configuration ──
# TAAL/GorillaPool policy: 0.1 sat/byte (100 sats/KB)
FEE_RATE=0.1
MIN_FEE=135
SPLIT_SATS=2000

# ── Game Configuration ──
TABLES_PER_NODE=16
SEATS_PER_TABLE=2
HANDS_PER_TABLE=2000
HAND_DELAY_MS=0
ACTION_DELAY_MS=0
STARTING_CHIPS=1000
ELIMINATION_MODE=true

# ── Apex Predator (AI) ──
# mock = heuristic only (zero cost)
# anthropic = Claude API (requires key)
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=

# ── Docker ──
FLOOR_RESTART=always
